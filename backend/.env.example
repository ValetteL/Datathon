# Copier ce fichier en .env (jamais committer .env !)
# cp .env.example .env

# Choisir le provider IA : GEMINI ou GROQ
IA_PROVIDER=GROQ

# ── Provider GROQ ─────────────────────────────────────────────────────────────
# Obtenir sur : https://console.groq.com → API Keys
GROQ_API_KEY=ta_cle_ici

# Modèle Groq — optionnel, défaut : llama-3.3-70b-versatile
# Alternatives : llama3-70b-8192 | mixtral-8x7b-32768 | gemma2-9b-it
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Provider GEMINI ───────────────────────────────────────────────────────────
# Obtenir sur : https://aistudio.google.com → Get API key
GOOGLE_API_KEY=ta_cle_ici

# Modèle Gemini — optionnel, défaut : gemini-2.0-flash
# Alternatives : gemini-2.5-flash | gemini-2.5-pro
# GEMINI_MODEL=gemini-2.0-flash
