# Copier ce fichier en .env (jamais committer .env !)
# cp .env.example .env

# Clé API Google Gemini — obligatoire
# Obtenir sur : https://aistudio.google.com → Get API key
GOOGLE_API_KEY=ta_cle_ici

# Modèle Gemini — optionnel, défaut : gemini-2.0-flash
# Changer selon ton quota et tes préférences :
#   gemini-2.0-flash        → rapide, Free Tier, ~1500 req/min  (défaut)
#   gemini-2.5-flash        → meilleur raisonnement, Free Tier
#   gemini-2.5-pro          → meilleur modèle, quota plus limité
# GEMINI_MODEL=gemini-2.0-flash
